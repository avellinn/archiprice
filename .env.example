# Copier vers .env à la racine archi-price/ (ne pas committer .env)
# cp .env.example .env

# ─── Backend ───────────────────────────────────────────
PORT=5000

# MongoDB — local :
# MONGODB_URI=mongodb://localhost:27017/archiprice
# MongoDB Atlas (encoder les caractères spéciaux du mot de passe dans l’URI) :
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/archiprice?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/archiprice
# Délai de découverte Atlas (DNS + sélection du replica set), en millisecondes.
MONGODB_SERVER_SELECTION_TIMEOUT_MS=30000

JWT_SECRET=changez-moi-en-production
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173

# Super Admin — seed automatique au premier démarrage avec MongoDB connecté.
# Si aucun admin n'existe, le backend crée ce compte avec role=admin et type="Super Admin".
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=!
SUPER_ADMIN_FIRSTNAME=Super
SUPER_ADMIN_LASTNAME=Admin

# Cloudinary — stockage images articles (aucun stockage disque local)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Uploads : budget total, délai par adresse réseau et nouvelles tentatives transitoires.
CLOUDINARY_UPLOAD_TIMEOUT_MS=120000
CLOUDINARY_UPLOAD_ATTEMPT_TIMEOUT_MS=20000
CLOUDINARY_UPLOAD_RETRIES=5

# ─── Frontend (production uniquement) ─────────────────
# En dev, Vite proxy /api → localhost:5000 (laisser vide ou commenter)
# VITE_API_URL=https://votre-api.example.com
